import matplotlib.image as image

def get_intensity(img_address):
    for imag, target in img_address:
        img = image.imread(imag)

        pixels_line_i = img[:,:,0].flatten()

        yield pixels_line_i, target

intensity_list = list(get_intensity(combined_file_list))
import collections
def cout(intensity_list):
    """
    count the number of occurrences of each intensity in an image
    """
    for i,target in intensity_list:
        counter=dict(collections.Counter(i))
        counter["Target"] = target
        yield counter
         
dict_intensity = list(cout(intensity_list))

    ind = 0
    col = [str(i) for i in range(256)] + ["Target"]
    df = pd.DataFrame(columns=col)
    
    for counter in dict_intensity:
        new_d = {str(key): [float(value)] for key, value in counter.items()}
        df = pd.concat([df, pd.DataFrame(new_d)], ignore_index=True)
        
df.fillna(0,inplace=True)

df["Target"] = df["Target"].astype(int)
features = list(df.columns)
features.remove('Target')
df[features] = df[features].astype('float32')

df

df_fault = df[df["Target"] == 0]
df_no_fault = df[df["Target"] == 1]

df_fault_describe = df_fault.describe()
df_no_fault_describe = df_no_fault.describe()

import matplotlib.pyplot as plt 
import seaborn as sns
plt.figure(figsize=(30,10))
plt.plot(df_fault_describe.loc["mean",features],color ='blue')
plt.plot(df_no_fault_describe.loc["mean",features],color ='orange')
plt.xticks(rotation=90);

X = df.drop("Target", axis=1)
Y = df["Target"]

from sklearn.preprocessing import RobustScaler
from sklearn.model_selection import train_test_split
X_train,X_test,Y_train,Y_test = train_test_split(X,Y,test_size=0.3, random_state=42)

print(X_train.shape,X_test.shape)

print(Y_train.shape,Y_test.shape)

rs = RobustScaler().fit(X_train)
X_train_std = rs.transform(X_train)
X_test_std = rs.transform(X_test)

from sklearn.svm import SVC
from sklearn.ensemble import RandomForestClassifier,AdaBoostClassifier
from sklearn.tree import DecisionTreeClassifier
from sklearn.linear_model import LogisticRegression
from sklearn.neighbors import KNeighborsClassifier
from sklearn.naive_bayes import GaussianNB

from datetime import datetime
start = datetime.now()
models = [SVC(C=15),RandomForestClassifier(),LogisticRegression(max_iter=1000),\
         DecisionTreeClassifier(),AdaBoostClassifier(),KNeighborsClassifier(),GaussianNB()]
         
result_frame = {model.__class__.__name__:list() for model in models}

from sklearn.metrics import accuracy_score,confusion_matrix,classification_report

for model in models:
    model.fit(X_train_std,Y_train)
    y_predict = model.predict(X_test_std)
    accuracy_test = accuracy_score(Y_test,y_predict)
    result_frame[model.__class__.__name__].append(accuracy_test)
    result_frame[model.__class__.__name__].append(classification_report(Y_test,y_predict,output_dict=True)\
                                                 ["weighted avg"]["f1-score"])
                                                 
for k,v in result_frame.items():
    print(k,len(v))

pd.DataFrame(result_frame,index=["Accuracy","f1-score"])

end = datetime.now()
print("model training and evaluation", end-start)

filters,kernel_size = 8,3

model = Sequential()

model.add(Conv2D(filters=filters, kernel_size=kernel_size,\
                input_shape=image_shape, activation='relu'))
model.add(MaxPooling2D(pool_size=(2,2)))

model.add(Flatten())
model.add(Dense(300,activation='relu'))

model.add(Dense(1, activation='sigmoid'))

model.compile(loss='binary_crossentropy',optimizer='adam',metrics=['accuracy'])

from datetime import datetime
start = datetime.now()
results = model.fit_generator(train_set,epochs=10)
end = datetime.now()
print("time taken",end-start)


